---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Admissions & Contact | Jyoti Girls PG"
  description="Complete the admission process for Jyoti Girls PG near Osmanpura with this step-by-step guide and contact information."
>

  <section style="padding: 60px 0 40px; background: var(--color-bg-base);">
    <div class="container">
      <span class="section-eyebrow">Girls PG near Osmanpura</span>
      <h1 class="section-heading">Admissions &amp; Contact</h1>
      <p class="section-lead">Follow this simple process to secure a bed at Jyoti Girls PG and stay connected with our admissions team.</p>
    </div>
  </section>

  <section style="background: var(--color-bg-white);">
    <div class="container">
      <h2 class="section-heading">Admission Steps</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;">
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">1. Enquiry &amp; Tour</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Submit the enquiry form or call us to schedule an in-person or virtual tour of the PG at your convenience.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">2. Application Form</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Fill in the resident details, guardian contacts, and coaching schedule. Our team assists throughout.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">3. Confirmation &amp; Deposit</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Pay the token amount to block your bed. Submit the security deposit and first month's rent within five days.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">4. Move-In &amp; Orientation</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Attend the orientation covering safety briefings, curfew rules, and introductions to caretakers.</p>
        </div>
      </div>
    </div>
  </section>

  <section style="background: var(--color-bg-subtle);">
    <div class="container">
      <h2 class="section-heading">Documentation Checklist</h2>
      <ul style="padding-left:20px;">
        <li style="color:var(--color-text-secondary);margin-bottom:8px;">Passport-size photographs of resident and guardian.</li>
        <li style="color:var(--color-text-secondary);margin-bottom:8px;">Copy of Aadhar card or valid ID for resident and guardian.</li>
        <li style="color:var(--color-text-secondary);margin-bottom:8px;">Latest academic report card and coaching admission slip.</li>
        <li style="color:var(--color-text-secondary);margin-bottom:8px;">Medical fitness certificate and allergy declarations, if any.</li>
      </ul>
    </div>
  </section>

  <section style="background: var(--color-bg-white);">
    <div class="container">
      <h2 class="section-heading">Payment &amp; Support</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-bottom:40px;">
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">Payment Modes</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Accepts bank transfer, UPI, and cheque. Receipts are shared within 24 hours of payment.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">Parent Helpline</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Call <a href="tel:+919922333305" style="color:var(--color-primary);">+91 99223 33305</a> between 9 AM and 9 PM or WhatsApp us for quick updates.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">Visit Address</h3>
          <p style="font-size:0.88rem;color:var(--color-text-secondary);">Vishwadeep, Jyoti Nagar, near Osmanpura, Chhatrapati Sambhajinagar, Maharashtra 431005.</p>
        </div>
      </div>
      <div class="card" style="background:var(--color-primary-pale);border-color:var(--color-primary-light);max-width:640px;">
        <h2 style="font-size:1.3rem;font-weight:600;margin-bottom:10px;">Ready to Join Jyoti Girls PG?</h2>
        <p style="color:var(--color-text-secondary);margin-bottom:20px;">Complete the enquiry form with your preferred move-in date, course, and room type. Our admissions counsellor will get back within one working day.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <button class="btn-primary" data-modal="availability">Check availability</button>
          <a href="https://wa.me/919922333305?text=Hello%20Jyoti%20Girls%20PG%2C%20I%20want%20to%20apply%20for%20admission." class="btn-whatsapp" target="_blank" rel="noopener noreferrer">Apply via WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
